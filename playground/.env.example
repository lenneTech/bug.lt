# Linear API Configuration
# Get your API key from Linear settings -> API
NUXT_LINEAR_API_KEY=your_linear_api_key_here

# Linear team name or key (e.g., "Development", "Backend", "DEV")
# The module will automatically resolve this to the team ID
NUXT_LINEAR_TEAM_NAME=Development

# Linear project name or key (optional, e.g., "Website", "Mobile App", "PROJ")
# If not specified, issues will be created without project assignment
# NUXT_LINEAR_PROJECT_NAME=Website

# HTTP Basic Authentication (optional)
# For pages behind htaccess/HTTP Basic Auth - required for screenshot functionality
# If your site is protected by HTTP Basic Auth, add credentials here
# NUXT_HTTP_AUTH_USERNAME=your_username
# NUXT_HTTP_AUTH_PASSWORD=your_password
